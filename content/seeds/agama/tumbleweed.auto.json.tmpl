{
  "_comment": "Agama unattended-install profile for openSUSE Tumbleweed. Same shape as leap.auto.json.tmpl; split for divergence (Tumbleweed gets newer pattern names occasionally).",
  "product": {
    "id": "Tumbleweed"
  },
  "localization": {
    "language": "en_US.UTF-8",
    "keyboard": "us",
    "timezone": "{{ .Cluster.Timezone | default "Asia/Seoul" }}"
  },
  "root": {
    "sshPublicKey": {{ printf "%q" (index .Node.SSHAuthorizedKeys 0) }},
    "password": "!"
  },
  "network": {
    "connections": [
      {
        "id": "{{ .Node.NetworkInterface }}",
        "interface": "{{ .Node.NetworkInterface }}",
        "method4": "manual",
        "addresses": ["{{ .Node.IP }}/{{ .Network.PrefixLen }}"],
        "gateway4": "{{ .Network.Gateway }}",
        "nameservers": ["{{ .Network.DNS }}"],
        "autoconnect": true
      }
    ]
  },
  "hostname": {
    "static": "{{ .Node.Hostname }}"
  },
  "storage": {
    "drives": [
      {
        "search": "*",
        "partitions": [
          { "search": "*", "delete": true },
          { "filesystem": { "type": "btrfs", "path": "/" }, "size": "min" }
        ]
      }
    ]
  },
  "software": {
    "products": ["Tumbleweed"],
    "patterns": ["base", "basesystem"],
    "packages": [
      "chrony",
      "python3",
      "openssh"{{ if .Node.NeedsCeph }},
      "lvm2",
      "podman"{{ end }}
    ]
  },
  "scripts": {
    "post": [
      {
        "name": "finalize",
        "body": "#!/bin/bash\nset -e\nhostnamectl set-hostname {{ .Node.Hostname }}\nsystemctl enable sshd chronyd\n"
      }
    ]
  }
}
